# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_publishable_key
# Server only. Never expose this value in browser code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Login
OWNER_EMAIL=keikamotushige@gmail.com
# A private one-time code required before the owner's first password is accepted.
OWNER_SETUP_CODE=replace_with_a_long_random_setup_code
TEST_EMAIL=test@translator.local
TEST_PASSWORD=TestPass123!
# Optional: multiple approved testers (comma-separated). Overrides TEST_EMAIL for the allowlist.
TEST_EMAILS=test@translator.local
